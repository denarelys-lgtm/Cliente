<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#000">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <ImageView
            android:id="@+id/viewScreen"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="fitCenter"
            android:background="#111" />

        <com.example.remoteclient.ResizableCameraContainer
            android:id="@+id/cameraContainer"
            android:layout_width="300dp"
            android:layout_height="200dp"
            android:layout_gravity="top|end"
            android:background="#44222222">

            <ImageView
                android:id="@+id/viewCamera"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop" />

        </com.example.remoteclient.ResizableCameraContainer>

        <!-- Indicador de estado de cámara -->
        <TextView
            android:id="@+id/txtCameraStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|start"
            android:layout_margin="16dp"
            android:text="Cámara detenida"
            android:textColor="@android:color/darker_gray"
            android:textSize="14sp"
            android:padding="8dp"
            android:background="#AA000000" />

    </FrameLayout>

    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#1A1A1A">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="10dp">

            <Button
                android:id="@+id/btnTglScreen"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PANTALLA"
                android:layout_margin="4dp" />

            <Button
                android:id="@+id/btnTglBack"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CAM TRAS"
                android:layout_margin="4dp" />

            <Button
                android:id="@+id/btnTglFront"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CAM FRONT"
                android:layout_margin="4dp" />

            <Button
                android:id="@+id/btnTglAudio"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="AUDIO"
                android:layout_margin="4dp" />

            <Button
                android:id="@+id/btnStopCamera"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PARAR CAM"
                android:layout_margin="4dp" />

            <Button
                android:id="@+id/btnStopAll"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PARAR TODO"
                android:layout_margin="4dp" />

        </LinearLayout>
    </HorizontalScrollView>

</LinearLayout>
